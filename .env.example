# Vercel cron auth
CRON_SECRET=replace-with-long-random-string

# X/Twitter API credentials (OAuth 1.0a user context)
# IMPORTANT: Access token must be generated with "Read and write" permissions.
# App-only Bearer token is NOT used for posting.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Optional but strongly recommended for high-quality generated posts
OPENAI_API_KEY=

# At least one news provider key is required
NEWS_API_KEY=
GNEWS_API_KEY=

# Optional but recommended to prevent duplicate posts across deployments
KV_REST_API_URL=
KV_REST_API_TOKEN=
